{
  "uid": "nginx-final",
  "title": "Nginx 访问日志分析",
  "tags": [
    "nginx",
    "loki"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "30s",
      "1m",
      "5m",
      "15m"
    ],
    "time_options": [
      "5m",
      "15m",
      "30m",
      "1h",
      "3h",
      "6h",
      "12h",
      "24h"
    ]
  },
  "annotations": {
    "list": []
  },
  "templating": {
    "list": [
      {
        "name": "node",
        "label": "🖥 服务器节点",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki-nginx"
        },
        "query": {
          "label": "node",
          "stream": "{job=\"nginx\"}",
          "type": 1
        },
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "server_name",
        "label": "🌐 域名过滤",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki-nginx"
        },
        "query": {
          "label": "server_name",
          "stream": "{job=\"nginx\",node=~\"$node\"}",
          "type": 1
        },
        "multi": false,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2,
        "sort": 1,
        "description": "选择单个域名后，IP排行/最新请求等面板查询量大幅减少"
      },
      {
        "name": "interval",
        "label": "⏱ 图表粒度",
        "type": "interval",
        "options": [
          {
            "text": "30s",
            "value": "30s"
          },
          {
            "text": "1m",
            "value": "1m"
          },
          {
            "text": "5m",
            "value": "5m"
          },
          {
            "text": "10m",
            "value": "10m"
          }
        ],
        "auto": false,
        "current": {
          "text": "1m",
          "value": "1m"
        }
      },
      {
        "name": "__refresh",
        "label": "🔄 手动刷新",
        "type": "custom",
        "description": "改变此值触发所有面板重新查询（相当于全局刷新按钮）",
        "options": [
          {
            "text": "1",
            "value": "1"
          },
          {
            "text": "2",
            "value": "2"
          },
          {
            "text": "3",
            "value": "3"
          },
          {
            "text": "4",
            "value": "4"
          },
          {
            "text": "5",
            "value": "5"
          }
        ],
        "current": {
          "text": "1",
          "value": "1"
        },
        "query": "1,2,3,4,5",
        "hide": 0,
        "multi": false,
        "includeAll": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "📊 请求汇总",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "总请求数",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-nginx"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"nginx\",node=~\"$node\",server_name=~\"$server_name\"} [$__range]))",
          "instant": true,
          "legendFormat": "请求总数"
        }
      ],
      "description": "⚡ 右上角菜单 → Explore 可单独刷新此面板查询"
    },
    {
      "id": 3,
      "type": "stat",
      "title": "1xx",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-nginx"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "fixedColor": "text",
            "mode": "fixed"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"nginx\",node=~\"$node\",server_name=~\"$server_name\",status_class=\"1xx\"} [$__range]))",
          "instant": true,
          "legendFormat": "1xx"
        }
      ],
      "description": "⚡ 右上角菜单 → Explore 可单独刷新此面板查询"
    },
    {
      "id": 4,
      "type": "stat",
