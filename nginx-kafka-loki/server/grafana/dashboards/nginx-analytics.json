      },
      "targets": [
        {
          "expr": "sum by (node) (count_over_time({job=\"nginx\",node=~\"$node\",server_name=~\"$server_name\",status_class=\"4xx\"} [$interval]))",
          "legendFormat": "4xx · {{node}}"
        },
        {
          "expr": "sum by (node) (count_over_time({job=\"nginx\",node=~\"$node\",server_name=~\"$server_name\",status_class=\"5xx\"} [$interval]))",
          "legendFormat": "5xx · {{node}}"
