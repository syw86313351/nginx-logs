          }
        }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"nginx\",node=~\"$node\",server_name=~\"$server_name\",status_class=\"4xx\"} [$__range]))",
          "instant": true,
          "legendFormat": "4xx"
        },
        {
          "expr": "sum(count_over_time({job=\"nginx\",node=~\"$node\",server_name=~\"$server_name\",status_class=\"5xx\"} [$__range]))",
          "instant": true,
          "legendFormat": "5xx"
        }
      ],
      "description": "⚡ 右上角菜单 → Explore 可单独刷新此面板查询"
    },
    {
      "id": 33,
      "type": "logs",
      "title": "错误详情（4xx+5xx 最新 100 条）— 点击行展开所有字段",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 31
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-nginx"
      },
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": false,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{job=\"nginx\",node=~\"$node\",server_name=~\"$server_name\",status_class=~\"4xx|5xx\"} | json | line_format \"[{{.status}}] {{.request_method}} {{.server_name}}{{.uri}} ← {{.client_ip}} | {{.request_time}}s | node:{{.node}}\"",
          "maxLines": 100
        }
      ]
    },
    {
      "id": 40,
      "type": "row",
      "title": "🐢 高延迟请求",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 41
      },
      "collapsed": false
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "响应时间分位数（P50 / P90 / P99）",
      "gridPos": {
        "h": 7,
        "w": 24,
        "x": 0,
        "y": 42
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-nginx"
      },
      "description": "先用标签缩小流集合，再 unwrap request_time。建议时间范围 ≤1h ⚡ 右上角菜单 → Explore 可单独刷新此面板查询",
      "fieldConfig": {
        "defaults": {
