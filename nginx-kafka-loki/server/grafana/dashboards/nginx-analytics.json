              {
                "color": "orange",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"nginx\",node=~\"$node\",server_name=~\"$server_name\",status_class=\"4xx\"} [$__range]))",
          "instant": true,
          "legendFormat": "4xx"
        }
      ],
      "description": "⚡ 右上角菜单 → Explore 可单独刷新此面板查询"
    },
    {
      "id": 7,
      "type": "stat",
      "title": "5xx 服务端错误",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "datasource": {
        "type": "loki",
