    {
      "id": 32,
      "type": "piechart",
      "title": "错误码占比（4xx vs 5xx）",
      "gridPos": {
        "h": 7,
        "w": 10,
        "x": 14,
        "y": 24
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-nginx"
      },
      "options": {
        "pieType": "donut",
        "legend": {
