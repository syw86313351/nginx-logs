    {
      "id": 10,
      "type": "row",
      "title": "📈 QPS & 状态码趋势",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "QPS — 按节点分组",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-nginx"
      },
      "description": "每条线代表一台节点的 QPS，纯标签查询，无需 | json ⚡ 右上角菜单 → Explore 可单独刷新此面板查询",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5,
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "last"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum by (node) (rate({job=\"nginx\",node=~\"$node\",server_name=~\"$server_name\"} [$interval]))",
          "legendFormat": "{{node}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "状态码趋势（1xx / 2xx / 3xx / 4xx / 5xx）",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-nginx"
      },
      "description": "所有状态码同一图表，走 status_class 标签，不扫日志体 ⚡ 右上角菜单 → Explore 可单独刷新此面板查询",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "1xx"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "blue",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "2xx"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "3xx"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "yellow",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "4xx"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "5xx"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum",
            "max"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"nginx\",node=~\"$node\",server_name=~\"$server_name\",status_class=\"1xx\"} [$interval]))",
          "legendFormat": "1xx"
        },
        {
          "expr": "sum(count_over_time({job=\"nginx\",node=~\"$node\",server_name=~\"$server_name\",status_class=\"2xx\"} [$interval]))",
          "legendFormat": "2xx"
        },
        {
          "expr": "sum(count_over_time({job=\"nginx\",node=~\"$node\",server_name=~\"$server_name\",status_class=\"3xx\"} [$interval]))",
          "legendFormat": "3xx"
        },
        {
          "expr": "sum(count_over_time({job=\"nginx\",node=~\"$node\",server_name=~\"$server_name\",status_class=\"4xx\"} [$interval]))",
          "legendFormat": "4xx"
        },
        {
          "expr": "sum(count_over_time({job=\"nginx\",node=~\"$node\",server_name=~\"$server_name\",status_class=\"5xx\"} [$interval]))",
          "legendFormat": "5xx"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "🌐 流量 I/O",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "collapsed": false
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "出入口带宽 — 按节点（实线=出口 / 虚线=入口）",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 15
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-nginx"
      },
      "description": "unwrap 查询，建议时间范围 ≤1h；出口=bytes_sent，入口=request_length ⚡ 右上角菜单 → Explore 可单独刷新此面板查询",
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 4,
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "入口.*"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [
                    6,
                    4
                  ]
                }
              },
              {
                "id": "custom.fillOpacity",
                "value": 0
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum by (node) (rate({job=\"nginx\",node=~\"$node\",server_name=~\"$server_name\"} | json | unwrap bytes_sent [$interval]))",
          "legendFormat": "出口 · {{node}}"
        },
        {
          "expr": "sum by (node) (rate({job=\"nginx\",node=~\"$node\",server_name=~\"$server_name\"} | json | unwrap request_length [$interval]))",
          "legendFormat": "入口 · {{node}}"
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "🚨 异常错误码",
