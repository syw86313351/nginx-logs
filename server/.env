# ========== 服务端配置 ==========
# 你的服务器 IP（客户端连 Kafka 时用这个地址），必须改成真实 IP
SERVER_IP=192.168.1.100

# 服务端端口
GRAFANA_PORT=3000
LOKI_PORT=3100

# 镜像版本（Kafka 使用 apache/kafka:3.7.0，直接写在 compose 中）
LOKI_IMAGE=grafana/loki:3.1.0
GRAFANA_IMAGE=grafana/grafana:11.0.0
ALLOY_IMAGE=grafana/alloy:latest

# ========== 服务端配置 ==========
# 你的服务器 IP（客户端连 Kafka 时用这个地址），必须改成真实 IP
SERVER_IP=192.168.1.100

# 服务端口
GRAFANA_PORT=3000
LOKI_PORT=3100
KAFKA_EXTERNAL_PORT=9094

# 镜像版本
LOKI_IMAGE=grafana/loki:3.1.0
GRAFANA_IMAGE=grafana/grafana:11.0.0
ALLOY_IMAGE=grafana/alloy:latest

